# Copie pra .env.production e preencha os valores.
# NUNCA commite .env.production no git.

# ── MySQL ─────────────────────────────────────────────────────
# Gere strings aleatórias fortes (openssl rand -base64 32)
MYSQL_ROOT_PASSWORD=change-me-strong-random-1
MYSQL_PASSWORD=change-me-strong-random-2

# ── Segredos do backend ───────────────────────────────────────
# openssl rand -base64 48 pra cada um
JWT_SECRET=change-me-strong-random-3
REFRESH_SECRET=change-me-strong-random-4

# ── CORS: origens permitidas (separadas por vírgula) ──────────
# Web dev / produção web + Capacitor Android + iOS
FRONTEND_URL=https://api.santoti.com,http://localhost:5173,capacitor://localhost,https://localhost

# ── ElevenLabs (voz da Sara) ──────────────────────────────────
# Copie do seu server/.env local
ELEVENLABS_API_KEY=sk_your_key_here
ELEVENLABS_SARA_VOICE_ID=your_voice_id_here
